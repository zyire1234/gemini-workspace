{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-service.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://your-backend-service.onrender.com/socket.io/:path*"
    },
    {
      "source": "/((?!api/|socket.io/|assets/).*)",
      "destination": "/index.html"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
