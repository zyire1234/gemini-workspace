{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "lib": ["ES2020"]
  },
  "include": ["serverold.ts"],
  "exclude": ["node_modules", "src", "vite.config.ts", "dist"]
}